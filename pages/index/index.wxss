page {
  background-color: #0d0d1a;
}

/* 开屏封面 */
.splash {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  background: #0d0d1a;
  opacity: 1;
  transition: opacity 0.4s ease;
}

.splash-hide {
  opacity: 0;
}

.splash-img {
  width: 100%;
  height: 100%;
}

.scroll {
  height: 100vh;
}

.map-wrap {
  position: relative;
  width: 100%;
}

.map-img {
  width: 100%;
  display: block;
}

.spot {
  position: absolute;
  border-radius: 6rpx;
  transition: background 0.08s;
}

.spot:active {
  background: rgba(233, 69, 96, 0.18);
}

.spot-ripple {
  position: absolute;
  inset: 0;
  border-radius: 6rpx;
  background: rgba(233, 69, 96, 0.22);
  border: 2rpx solid rgba(233, 69, 96, 0.8);
  box-shadow: 0 0 20rpx rgba(233, 69, 96, 0.45);
  animation: spot-flash 0.38s ease-out forwards;
}

@keyframes spot-flash {
  0%   { opacity: 0;   transform: scale(0.88); }
  45%  { opacity: 1;   transform: scale(1.04); }
  100% { opacity: 0.85; transform: scale(1); }
}

.tip {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.tip-text {
  color: #666;
  font-size: 28rpx;
}
