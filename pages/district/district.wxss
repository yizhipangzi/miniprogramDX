page {
  background: #0d0d1a;
}

/* 加载进度条 */
.loading-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: #0d0d1a;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.loading-box {
  width: 60%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-text {
  color: #e0e0ef;
  font-size: 26rpx;
  margin-bottom: 20rpx;
}

.loading-track {
  width: 100%;
  height: 10rpx;
  border-radius: 6rpx;
  background: #23233a;
  overflow: hidden;
}

.loading-fill {
  height: 100%;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #5b8cff, #8a5bff);
  /* 短过渡：平滑下载阶段分块跳变，又能紧跟渲染阶段的 JS 补间，不拖尾 */
  transition: width 0.12s linear;
}

.err-banner {
  padding: 60rpx 32rpx;
  background: #2a0a10;
}

.err-text {
  display: block;
  color: #e94560;
  font-size: 28rpx;
  line-height: 1.6;
}

/* Header */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #1e1e3a;
}

.header-left {
  flex: 1;
  min-width: 0;
}

.district-name {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #f0f0f0;
  letter-spacing: 2rpx;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
}

/* Mode switch */
.mode-switch {
  display: flex;
  flex-shrink: 0;
  background: #16162a;
  border-radius: 14rpx;
  padding: 4rpx;
  border: 1rpx solid #252545;
}

.mode-btn {
  width: 72rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  border-radius: 11rpx;
  opacity: 0.45;
  transition: all 0.15s;
}

.mode-active {
  background: #e94560;
  opacity: 1;
}

/* List */
.list {
  padding: 16rpx 0 60rpx;
}

/* Theater card */
.theater-card {
  display: flex;
  align-items: center;
  background: #1a1a2e;
  margin: 12rpx 24rpx;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  border: 1rpx solid #252545;
}

.theater-card:active {
  background: #252545;
}

.theater-icon {
  font-size: 44rpx;
  width: 72rpx;
  text-align: center;
  flex-shrink: 0;
}

.theater-info {
  flex: 1;
  margin-left: 20rpx;
}

.theater-name {
  display: block;
  font-size: 30rpx;
  color: #f0f0f0;
  font-weight: 500;
  line-height: 1.4;
}

.theater-meta {
  display: block;
  font-size: 24rpx;
  color: #e94560;
  margin-top: 8rpx;
}

.theater-arrow {
  font-size: 44rpx;
  color: #888;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* Movie card */
.movie-card {
  background: #1a1a2e;
  margin: 12rpx 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid #252545;
  overflow: hidden;
}

.movie-head {
  display: flex;
  align-items: stretch;
}

.score-block {
  width: 96rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 8rpx;
  opacity: 0.95;
}

.score-type {
  font-size: 18rpx;
  color: #fff;
  opacity: 0.85;
  letter-spacing: 1rpx;
}

.score-val {
  font-size: 38rpx;
  font-weight: 700;
  color: #fff;
  margin-top: 4rpx;
}

.score-link {
  font-size: 26rpx;
  color: #fff;
  opacity: 0.7;
  margin-top: 2rpx;
}

.movie-body {
  flex: 1;
  padding: 20rpx 16rpx;
  min-width: 0;
}

.title-jp {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #f0f0f0;
  line-height: 1.4;
}

.title-cn {
  display: block;
  font-size: 24rpx;
  color: #aaa;
  margin-top: 6rpx;
  line-height: 1.3;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.tag {
  font-size: 20rpx;
  color: #e94560;
  background: rgba(233, 69, 96, 0.12);
  border: 1rpx solid rgba(233, 69, 96, 0.3);
  border-radius: 6rpx;
  padding: 2rpx 12rpx;
}

.movie-meta {
  display: block;
  font-size: 22rpx;
  color: #888;
  margin-top: 12rpx;
}

.movie-arrow {
  flex-shrink: 0;
  width: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #888;
}

/* Screenings (expanded) */
.screenings {
  border-top: 1rpx solid #252545;
  padding: 8rpx 24rpx 16rpx;
}

.screening-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #20203a;
}

.screening-row:last-child {
  border-bottom: none;
}

.sc-time {
  flex-shrink: 0;
  width: 110rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #f0f0f0;
  letter-spacing: 1rpx;
}

.sc-tags {
  flex-shrink: 0;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  margin-left: 8rpx;
}

.sc-theater {
  flex: 1;
  font-size: 24rpx;
  color: #aaa;
  margin-left: 16rpx;
  line-height: 1.4;
}

.sc-link {
  flex-shrink: 0;
  font-size: 26rpx;
  color: #e94560;
  margin-left: 12rpx;
}

.screening-row:active {
  opacity: 0.6;
}

.empty {
  padding: 120rpx 0;
  text-align: center;
}

.empty-text {
  color: #888;
  font-size: 28rpx;
}

/* ===== 电影详情浮层 ===== */
.detail-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.65);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.2s;
  z-index: 100;
}

.mask-show {
  opacity: 1;
  visibility: visible;
}

.detail-card {
  position: relative;
  display: flex;
  flex-direction: column;
  width: 86vw;
  /* 定高（非 max-height）：scroll-view 只有在祖先链高度确定时，flex:1 才能拿到
     具体高度并真正内部滚动；否则会在原生层把手势透传给背后页面。 */
  height: 82vh;
  background: #16162a;
  border-radius: 24rpx;
  border: 1rpx solid #2a2a4a;
  box-shadow: 0 12rpx 60rpx rgba(0, 0, 0, 0.6);
  overflow: hidden;
}

.detail-close {
  position: absolute;
  top: 16rpx;
  right: 20rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #aaa;
  background: rgba(0, 0, 0, 0.35);
  border-radius: 50%;
  z-index: 2;
}

.detail-scroll {
  /* 父级 .detail-card 已是定高 82vh，这里 flex:1 即可拿到具体高度，内部可滚动。 */
  flex: 1;
  min-height: 0;
  box-sizing: border-box;
}

/* 内层承担内边距：scroll-view 自身的 padding-bottom 不计入可滚动区域，
   会把最后一条短评挡住，所以把 padding 放到内层 view 上。 */
.detail-inner {
  padding: 40rpx 36rpx;
  box-sizing: border-box;
}

.detail-top {
  display: flex;
  align-items: flex-start;
}

.detail-poster {
  width: 220rpx;
  height: 300rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #0d0d1a;
}

.poster-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.poster-ph-text {
  font-size: 72rpx;
  opacity: 0.4;
}

.detail-headinfo {
  flex: 1;
  margin-left: 24rpx;
  min-width: 0;
  padding-right: 40rpx;
}

.detail-title-jp {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #f0f0f0;
  line-height: 1.35;
}

.detail-title-cn {
  display: block;
  font-size: 26rpx;
  color: #aaa;
  margin-top: 8rpx;
  line-height: 1.3;
}

.detail-yearcountry {
  display: block;
  font-size: 24rpx;
  color: #777;
  margin-top: 12rpx;
}

.detail-scoreline {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 28rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #252545;
}

.ds-star {
  font-size: 36rpx;
  font-weight: 700;
}

.ds-source {
  font-size: 22rpx;
  color: #888;
}

.ds-sep {
  color: #444;
  font-size: 24rpx;
}

.ds-meta {
  font-size: 24rpx;
  color: #aaa;
}

.detail-row {
  display: flex;
  margin-top: 24rpx;
}

.dr-label {
  flex-shrink: 0;
  width: 140rpx;
  font-size: 26rpx;
  color: #888;
}

.dr-value {
  flex: 1;
  font-size: 26rpx;
  color: #e8e8e8;
  line-height: 1.5;
}

.detail-comment {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #252545;
}

.dc-label {
  display: block;
  font-size: 26rpx;
  color: #888;
  margin-bottom: 12rpx;
}

.dc-item {
  margin-top: 16rpx;
  padding-left: 16rpx;
  border-left: 3rpx solid #3a3a5c;
}

.dc-item:first-child {
  margin-top: 0;
}

.dc-text {
  display: block;
  font-size: 26rpx;
  color: #ccc;
  line-height: 1.6;
}
