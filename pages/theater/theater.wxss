page {
  background: #0d0d1a;
  min-height: 100vh;
}

.header {
  padding: 32rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #1e1e3a;
}

.theater-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #f0f0f0;
  line-height: 1.4;
}

.subtitle {
  display: block;
  font-size: 22rpx;
  color: #666;
  margin-top: 8rpx;
}

.list {
  padding: 16rpx 0 40rpx;
}

/* Movie card */
.movie-card {
  display: flex;
  flex-direction: row;
  background: #1a1a2e;
  margin: 12rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid #252545;
  border-left-width: 8rpx;
}

.score-block {
  width: 100rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 8rpx;
  opacity: 0.95;
}

.score-type {
  font-size: 18rpx;
  color: #fff;
  opacity: 0.85;
  letter-spacing: 1rpx;
}

.score-val {
  font-size: 38rpx;
  font-weight: 700;
  color: #fff;
  margin-top: 4rpx;
}

.movie-body {
  flex: 1;
  padding: 20rpx 20rpx 20rpx 16rpx;
  min-width: 0;
}

.title-jp {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #f0f0f0;
  line-height: 1.4;
}

.title-cn {
  display: block;
  font-size: 24rpx;
  color: #aaa;
  margin-top: 6rpx;
  line-height: 1.3;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.tag {
  font-size: 20rpx;
  color: #e94560;
  background: rgba(233, 69, 96, 0.12);
  border: 1rpx solid rgba(233, 69, 96, 0.3);
  border-radius: 6rpx;
  padding: 2rpx 12rpx;
}

.meta {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #666;
}

.director {
  display: block;
  font-size: 22rpx;
  color: #888;
  margin-top: 6rpx;
}

.showtimes {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.showtime-chip {
  display: inline-flex;
  align-items: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #f0f0f0;
  background: rgba(255, 255, 255, 0.07);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 8rpx;
  padding: 6rpx 14rpx;
}

.showtime-chip .st-time {
  letter-spacing: 1rpx;
}

/* 无在线购票的影院：场次仅展示、不可点击 */
.showtime-chip.no-online {
  opacity: 0.7;
}

.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-text {
  color: #444;
  font-size: 28rpx;
}

.footer-pad {
  height: 40rpx;
}

.err-banner {
  padding: 60rpx 32rpx;
  background: #2a0a10;
}

.err-text {
  display: block;
  color: #e94560;
  font-size: 28rpx;
  line-height: 1.6;
}
